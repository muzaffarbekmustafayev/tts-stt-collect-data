# Telegram Bot Configuration
BOT_API_TOKEN=your_telegram_bot_token_here

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/ttsdb
MONGODB_URL=mongodb://localhost:27017/ttsdb

# Audio Limits
sentence_to_audio_limit=30
user_sent_audio_limit=10000000000
user_check_audio_limit=10000000000
audio_check_limit=3

# Timeout Settings (in minutes)
pending_audio_timeout_minutes=10

# Security
SECRET_KEY=your_secret_key_minimum_32_characters_long_for_security
ACCESS_TOKEN_EXPIRE_MINUTES=1440
